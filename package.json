{
  "name": "langmap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:map": "node scripts/generate-map.js && node scripts/optimise-map.js",
    "build": "node scripts/build-graph.js && node scripts/optimise-map.js && vite build",
    "preview": "vite preview",
