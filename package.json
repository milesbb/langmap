    "d3-zoom": "^3.0.0",
    "gsap": "^3.12.5",
    "howler": "^2.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.44",
    "@vitest/coverage-v8": "^1.6.0",
    "axe-core": "^4.9.1",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "svgo": "^3.3.2",
    "vite": "^5.2.11",
    "vitest": "^1.6.0",
    "vitest-axe": "^0.1.0"
  }
